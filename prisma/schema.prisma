generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
}

model WeeklyProject {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  summary       String?
  description   String
  targetAmount  Int
  currentAmount Int      @default(0)
  imageUrls     String[]
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TubewellProject {
  id          String    @id @default(cuid())
  title       String
  location    String?
  description String
  completedAt DateTime?
  imageUrls   String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model DonationApplication {
  id              String   @id @default(cuid())
  fullName        String
  phone           String
  email           String?
  address         String?
  amountRequested Int?
  reason          String
  status          String   @default("pending")
  createdAt       DateTime @default(now())
}
